{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:deny-internal-toggle-devtools",
    "core:webview:deny-set-webview-zoom",
    "updater:default",
    "autostart:default",
    "global-shortcut:default"
  ]
}