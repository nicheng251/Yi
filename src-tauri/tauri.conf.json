{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yi",
  "version": "0.1.0",
  "identifier": "com.yi.focus",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Yi - 专注生产力工具",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Focus Productivity Tool",
    "longDescription": "Yi is a desktop productivity application designed for long-term focus tracking with project timers and daily achievement records.",
    "category": "Productivity",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}